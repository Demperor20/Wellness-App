{
  "entities": {
    "users": {
      "title": "User Profile",
      "description": "Stores user profile information and onboarding status.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "onboardingComplete": { "type": "boolean" },
        "vitalityGoal": { "type": "string", "enum": ["longevity", "performance", "balance"] },
        "streakSettings": {
          "type": "object",
          "properties": {
            "workModeHours": { "type": "number", "description": "Hours dedicated to work mode (default 8)" },
            "personalModeHours": { "type": "number", "description": "Hours dedicated to personal/family/leisure (default 8)" },
            "workGoals": { "type": "array", "items": { "type": "string" } },
            "personalGoals": { "type": "array", "items": { "type": "string" } }
          }
        },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "onboardingComplete"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "users",
      "description": "User profile documents"
    }
  }
}
