{
  "entities": {
    "users": {
      "title": "User Profile",
      "description": "Stores user profile information and onboarding status.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "onboardingComplete": { "type": "boolean" },
        "vitalityGoal": { "type": "string", "enum": ["longevity", "performance", "balance"] },
        "streakSettings": {
          "type": "object",
          "properties": {
            "workModeHours": { "type": "number" },
            "personalModeHours": { "type": "number" },
            "workGoals": { "type": "array", "items": { "type": "string" } },
            "personalGoals": { "type": "array", "items": { "type": "string" } },
            "postureReminderMinutes": { "type": "number", "default": 50 },
            "hydrationGoal": { "type": "number", "description": "Daily hydration goal in ml" },
            "livingActivities": { "type": "array", "items": { "type": "string" } },
            "socialUsage": {
              "type": "object",
              "properties": {
                "facebook": { "type": "number", "default": 0 },
                "instagram": { "type": "number", "default": 0 },
                "twitter": { "type": "number", "default": 0 },
                "whatsapp": { "type": "number", "default": 0 }
              }
            },
            "socialConnections": {
              "type": "object",
              "properties": {
                "facebook": { "type": "boolean", "default": false },
                "instagram": { "type": "boolean", "default": false },
                "twitter": { "type": "boolean", "default": false },
                "whatsapp": { "type": "boolean", "default": false }
              }
            }
          }
        },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "onboardingComplete"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "users",
      "description": "User profile documents"
    }
  }
}
