{
  "entities": {
    "users": {
      "title": "User Profile",
      "description": "Stores user profile information and onboarding status.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "onboardingComplete": { "type": "boolean" },
        "vitalityGoal": { "type": "string", "enum": ["longevity", "performance", "balance"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "onboardingComplete"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "users",
      "description": "User profile documents"
    }
  }
}
